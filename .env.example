# ── Scoring model (CodeLlama-7B-Instruct via LM Studio) ──────────────────────
SCORING_MODEL_HOST=http://localhost:1234
SCORING_MODEL_NAME=codellama-7b-instruct

# ── Feedback model (CodeGemma via Ollama) ─────────────────────────────────────
# Ollama serves CodeGemma on port 11434 (LM Studio serves CodeLlama on port 1234)
FEEDBACK_MODEL_HOST=http://localhost:11434
FEEDBACK_MODEL_NAME=codegemma:7b-instruct

# ── QLoRA fine-tune output ─────────────────────────────────────────────────────
FINETUNE_OUTPUT_PATH=finetune_samples.jsonl

# ── Legacy fallback (kept for app.py / app-simple.py compatibility) ────────────
MODEL_HOST=http://localhost:1234
MODEL_NAME=codellama-7b-instruct

# ── Flask API ─────────────────────────────────────────────────────────────────
API_PORT=5050